#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["cyclopts"]
# ///
"""Cleanup local git branches that have been merged via GitHub PRs."""

from __future__ import annotations

import concurrent.futures
import json
import logging
import subprocess
from typing import Annotated

import cyclopts

app = cyclopts.App(help=__doc__, default_parameter=cyclopts.Parameter(negative=()))
logger = logging.getLogger(__name__)


def run_cmd(command_args: list[str]) -> str:
    result = subprocess.run(command_args, capture_output=True, text=True, check=False)
    return result.stdout


def get_local_branches() -> set[str]:
    return {
        branch.removeprefix("*").strip()
        for branch in run_cmd(["git", "branch"]).splitlines()
    }


def get_remote_branches(remote: str = "origin") -> set[str]:
    prefix = f"{remote}/"
    return {
        branch.strip().removeprefix(prefix)
        for branch in run_cmd(["git", "branch", "-r"]).splitlines()
        if branch.strip().startswith(prefix) and not branch.strip().endswith("/HEAD")
    }


def _check_branch_merged(branch: str) -> str | None:
    """Return the branch name if it has a merged PR, else None."""
    logger.debug(f"Checking PR status for branch: {branch}")
    result = run_cmd(
        [
            "gh",
            "pr",
            "list",
            "--head",
            branch,
            "--state",
            "merged",
            "--json",
            "number",
            "--limit",
            "1",
        ]
    )
    prs = json.loads(result) if result.strip() else []
    if prs:
        logger.debug(f"  -> merged (PR #{prs[0]['number']})")
        return branch
    logger.debug(f"  -> not merged")
    return None


def get_merged_branches(local_branches: set[str]) -> set[str]:
    """Check which local branches have merged PRs using gh CLI."""
    with concurrent.futures.ThreadPoolExecutor() as executor:
        results = executor.map(_check_branch_merged, local_branches)
    return {branch for branch in results if branch is not None}


def cleanup_local_git_branches(
    protected_branches: set[str],
    dry_run: bool = False,
) -> None:
    local_branches = get_local_branches() - protected_branches
    logger.debug(f"Local branches (excluding protected): {sorted(local_branches)}")

    branches_to_delete = get_merged_branches(local_branches)

    if not branches_to_delete:
        logger.info("No local branches to cleanup!")
    else:
        logger.info("Merged local branches:")
        for branch in sorted(branches_to_delete):
            logger.info(f"  - {branch}")

        if dry_run:
            logger.info("\nDry run, no local branches deleted.")
        elif input("\nDelete these local branches? (y/n) ").strip().lower() == "y":
            subprocess.run(["git", "branch", "-D", *branches_to_delete])
            logger.info("Done!")
        else:
            logger.info("Aborted.")


def cleanup_remote_git_branches(
    protected_branches: set[str],
    remote: str = "origin",
    dry_run: bool = False,
) -> None:
    run_cmd(["git", "fetch", remote, "--prune"])

    remote_branches = get_remote_branches(remote) - protected_branches
    logger.debug(f"Remote branches (excluding protected): {sorted(remote_branches)}")

    branches_to_delete = get_merged_branches(remote_branches)

    if not branches_to_delete:
        logger.info("No remote branches to cleanup!")
        return

    logger.info("Merged remote branches:")
    for branch in sorted(branches_to_delete):
        logger.info(f"  - {remote}/{branch}")

    if dry_run:
        logger.info("\nDry run, no remote branches deleted.")
        return

    if input("\nDelete these remote branches? (y/n) ").strip().lower() == "y":
        subprocess.run(["git", "push", remote, "--delete", *sorted(branches_to_delete)])
        logger.info("Done!")
    else:
        logger.info("Aborted.")


@app.default
def main(
    *,
    protected: tuple[str, ...] = ("master", "main"),
    dry_run: bool = False,
    verbose: Annotated[bool, cyclopts.Parameter(alias="-v")] = False,
) -> None:
    logging.basicConfig(
        level=logging.DEBUG if verbose else logging.INFO,
        format="[%(levelname)s] %(message)s",
    )

    protected_branches = set(protected)

    cleanup_local_git_branches(
        protected_branches=protected_branches,
        dry_run=dry_run,
    )

    logger.info("")
    cleanup_remote_git_branches(
        protected_branches=protected_branches,
        dry_run=dry_run,
    )


if __name__ == "__main__":
    app()
